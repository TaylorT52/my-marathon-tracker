rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function permanentUser() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider != "anonymous";
    }

    function raceAfter(raceId) {
      return getAfter(/databases/$(database)/documents/races/$(raceId));
    }

    function isMember(raceId) {
      return signedIn()
        && exists(/databases/$(database)/documents/races/$(raceId)/members/$(request.auth.uid));
    }

    function isOwner(raceId) {
      return signedIn()
        && get(/databases/$(database)/documents/races/$(raceId)).data.ownerId == request.auth.uid;
    }

    function validRaceCreate() {
      return permanentUser()
        && request.resource.data.keys().hasOnly([
          "ownerId",
          "raceName",
          "runnerName",
          "targetDistanceMiles",
          "isPrivate",
          "status",
          "createdAt"
        ])
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.raceName is string
        && request.resource.data.raceName.size() > 0
        && request.resource.data.raceName.size() <= 80
        && request.resource.data.runnerName is string
        && request.resource.data.runnerName.size() > 0
        && request.resource.data.runnerName.size() <= 60
        && request.resource.data.targetDistanceMiles is number
        && request.resource.data.targetDistanceMiles >= 0.1
        && request.resource.data.targetDistanceMiles <= 500
        && request.resource.data.isPrivate is bool
        && request.resource.data.status == "setup"
        && request.resource.data.createdAt == request.time;
    }

    match /races/{raceId} {
      allow get: if resource.data.isPrivate == false
        || isMember(raceId)
        || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow list: if resource.data.isPrivate == false
        || (signedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if validRaceCreate();
      allow update: if isOwner(raceId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"])
        && request.resource.data.status in ["setup", "live", "paused", "ended"];
      allow delete: if isOwner(raceId);

      match /members/{userId} {
        allow read: if isMember(raceId) || isOwner(raceId);
        allow create: if signedIn()
          && userId == request.auth.uid
          && request.resource.data.joinedAt == request.time
          && (
            (
              request.resource.data.keys().hasOnly(["role", "joinedAt"])
              && request.resource.data.role == "runner"
              && raceAfter(raceId).data.ownerId == request.auth.uid
            )
            ||
            (
              request.resource.data.keys().hasOnly(["role", "joinedAt"])
              && request.resource.data.role == "spectator"
              && raceAfter(raceId).data.isPrivate == false
              && raceAfter(raceId).data.status != "ended"
            )
            ||
            (
              request.resource.data.keys().hasOnly(["role", "inviteHash", "joinedAt"])
              && request.resource.data.role == "spectator"
              && request.resource.data.inviteHash is string
              && request.resource.data.inviteHash.size() == 64
              && get(/databases/$(database)/documents/raceInvites/$(request.resource.data.inviteHash)).data.raceId == raceId
              && get(/databases/$(database)/documents/raceInvites/$(request.resource.data.inviteHash)).data.expiresAt > request.time
              && raceAfter(raceId).data.status != "ended"
            )
          );
        allow update, delete: if false;
      }

      match /state/{stateId} {
        allow read: if isMember(raceId);
        allow create: if isOwner(raceId)
          && stateId == "latest"
          && request.resource.data.keys().hasOnly([
            "latitude",
            "longitude",
            "distanceMiles",
            "elapsedSeconds",
            "paceSeconds",
            "isTracking",
            "isFinished",
            "recordedAt"
          ])
          && request.resource.data.latitude is number
          && request.resource.data.latitude >= -90
          && request.resource.data.latitude <= 90
          && request.resource.data.longitude is number
          && request.resource.data.longitude >= -180
          && request.resource.data.longitude <= 180
          && request.resource.data.distanceMiles is number
          && request.resource.data.distanceMiles >= 0
          && request.resource.data.distanceMiles <= 500
          && request.resource.data.elapsedSeconds is number
          && request.resource.data.elapsedSeconds >= 0
          && request.resource.data.elapsedSeconds <= 604800
          && request.resource.data.paceSeconds is number
          && request.resource.data.paceSeconds >= 0
          && request.resource.data.paceSeconds <= 86400
          && request.resource.data.isTracking is bool
          && request.resource.data.isFinished is bool
          && (!request.resource.data.isFinished || !request.resource.data.isTracking)
          && request.resource.data.recordedAt == request.time;
        allow update: if isOwner(raceId)
          && stateId == "latest"
          && request.resource.data.keys().hasOnly([
            "latitude",
            "longitude",
            "distanceMiles",
            "elapsedSeconds",
            "paceSeconds",
            "isTracking",
            "isFinished",
            "recordedAt"
          ])
          && request.resource.data.latitude is number
          && request.resource.data.latitude >= -90
          && request.resource.data.latitude <= 90
          && request.resource.data.longitude is number
          && request.resource.data.longitude >= -180
          && request.resource.data.longitude <= 180
          && request.resource.data.distanceMiles is number
          && request.resource.data.distanceMiles >= resource.data.distanceMiles
          && request.resource.data.distanceMiles <= 500
          && request.resource.data.elapsedSeconds is number
          && request.resource.data.elapsedSeconds >= resource.data.elapsedSeconds
          && request.resource.data.elapsedSeconds <= 604800
          && request.resource.data.paceSeconds is number
          && request.resource.data.paceSeconds >= 0
          && request.resource.data.paceSeconds <= 86400
          && request.resource.data.isTracking is bool
          && request.resource.data.isFinished is bool
          && (!request.resource.data.isFinished || !request.resource.data.isTracking)
          && (
            !resource.data.keys().hasAny(["isFinished"])
            || resource.data.isFinished == false
            || request.resource.data.isFinished == true
          )
          && request.resource.data.recordedAt == request.time
          && request.resource.data.recordedAt > resource.data.recordedAt;
        allow delete: if isOwner(raceId);
      }

      match /updates/{updateId} {
        allow read: if isMember(raceId);
        allow create: if isOwner(raceId)
          && request.resource.data.keys().hasOnly(["message", "mile", "sentAt"])
          && request.resource.data.message is string
          && request.resource.data.message.size() > 0
          && request.resource.data.message.size() <= 280
          && request.resource.data.mile is number
          && request.resource.data.mile >= 0
          && request.resource.data.mile <= 500
          && request.resource.data.sentAt == request.time;
        allow update: if false;
        allow delete: if isOwner(raceId);
      }
    }

    match /raceInvites/{inviteHash} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if permanentUser()
        && inviteHash.size() == 64
        && request.resource.data.keys().hasOnly([
          "raceId",
          "ownerId",
          "expiresAt",
          "createdAt"
        ])
        && request.resource.data.ownerId == request.auth.uid
        && raceAfter(request.resource.data.raceId).data.ownerId == request.auth.uid
        && raceAfter(request.resource.data.raceId).data.isPrivate == true
        && request.resource.data.createdAt == request.time
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.time
        && request.resource.data.expiresAt <= request.time + duration.value(72, "h");
      allow update: if false;
      allow delete: if signedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
